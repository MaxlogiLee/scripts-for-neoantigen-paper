"MS_PCA-01-BDI","MS_PCA-01-SVI","MS_PCA-05-PVLN-L","MS_PCA-04-OBLN-L","MS_PCA-04-OBLN-R","MS_PCA-04-EILN",
"grep_PCA-06-CILN-L","grep_PCA-06-IILN-R")])
dat$Meta_N=rowSums(dat[,c("MS_PCA-01-L1","MS_PCA-01-SCLN","MS_PCA-01-MLN","MS_PCA-01-PMI","MS_PCA-01-RMLN",
"MS_PCA-01-BDI","MS_PCA-01-SVI","MS_PCA-05-PVLN-L","MS_PCA-04-OBLN-L","MS_PCA-04-OBLN-R","MS_PCA-04-EILN",
"grep_PCA-06-CILN-L","grep_PCA-06-IILN-R")])
dat[,c("MS_PCA-01-L1","MS_PCA-01-SCLN","MS_PCA-01-MLN","MS_PCA-01-PMI","MS_PCA-01-RMLN",
"MS_PCA-01-BDI","MS_PCA-01-SVI","MS_PCA-05-PVLN-L","MS_PCA-04-OBLN-L","MS_PCA-04-OBLN-R","MS_PCA-04-EILN",
"grep_PCA-06-CILN-L","grep_PCA-06-IILN-R")]
dat$Meta_N=rowSums(dat[,c("MS_PCA-01-L1","MS_PCA-01-SCLN","MS_PCA-01-MLN","MS_PCA-01-PMI","MS_PCA-01-RMLN",
"MS_PCA-01-BDI","MS_PCA-01-SVI","MS_PCA-05-PVLN-L","MS_PCA-04-OBLN-L","MS_PCA-04-OBLN-R","MS_PCA-04-EILN",
"MS_PCA-06-CILN-L","MS_PCA-06-IILN-R")])
plot_df=dat[dat$Meta_N>0,]%>%
group_by(`source-annotated`)%>%summarise(N=length(unique(Peptide)))
plot_df$Var1=factor(plot_df$`source-annotated`,levels = rev(c("Mutation","Fusion","IR","TElocal","TEprof2","DN","Cis","Trans")))
ggplot(plot_df,aes(x=N,y=Var1,fill=Var1))+geom_col()+
scale_fill_manual(values=type_col)+
guides(fill=guide_legend(reverse = T,title="Source Annotated",ncol = 2))+
geom_text(aes(label = N),hjust=-0.1,size = 2.3, fontface = 'bold')+
xlab("No. of ncHLAps")+
theme_pubr()+
theme(legend.position = "right",
axis.text.x = element_text(size = 9),
axis.text.y = element_text(hjust=0.5,vjust=0.5,size = 8),
axis.line.x = element_line(color = 'black', linewidth = 0.5),
axis.line.y = element_line(color = 'black', linewidth = 0.5),
plot.title = element_text(hjust = 0.5, size = 12, face = 'bold',
margin = margin(b = 10)))+ylab("")+
scale_x_continuous(expand = expansion(mult = c(0, 0.1)))
